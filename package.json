{
	"name": "my-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:setup": "npm run db:start:d && sleep 3 && npm run db:push:test",
		"test:full": "npm run test:setup && npx vitest",
		"db:start": "docker compose up",
		"db:start:d": "docker compose up -d",
		"db:stop": "docker compose down",
		"db:reset": "drizzle-kit drop && npm run db:push",
		"db:push": "drizzle-kit push --force",
		"db:push:test": "DATABASE_URL=postgres://root:mysecretpassword@localhost:5433/test_pong npm run db:push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:studio:test": "DATABASE_URL=postgres://root:mysecretpassword@localhost:5433/test_pong drizzle-kit studio",
		"db:seed:test": "DATABASE_URL=postgres://root:mysecretpassword@localhost:5433/test_pong npx tsx src/lib/server/db/test_db/seed.ts",
		"db:seed": "npx tsx src/lib/server/db/seed.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@oslojs/crypto": "^1.0.1",
		"@oslojs/encoding": "^1.1.0",
		"@playwright/test": "^1.57.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.0.15",
		"drizzle-kit": "^0.31.8",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"pino-pretty": "^13.1.3",
		"playwright": "^1.57.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.48.1",
		"vite": "^7.2.6",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@lucia-auth/adapter-drizzle": "^1.1.0",
		"@node-rs/argon2": "^2.0.2",
		"@supabase/supabase-js": "^2.95.3",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"lucia": "^3.2.2",
		"pino": "^10.3.1",
		"postgres": "^3.4.7",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"zod": "^4.3.6"
	}
}
